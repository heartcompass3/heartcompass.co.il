---
---

<footer class="bg-[#0f172a] text-white mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16">

    <div class="grid grid-cols-1 md:grid-cols-6 gap-12">

      <div>
        <h3 class="text-2xl font-bold mb-4">מצפן הלב</h3>
        <p class="text-white/70 leading-relaxed">
          לבחור מתוך תשוקה ולא מתוך פחד.
          תהליך עומק לזיהוי חסמים, שחרור דפוסים ובניית דרך מדויקת.
        </p>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4">תחומי אימון</h4>
        <ul class="space-y-2 text-white/70">
          <li><a href="/specialties/couples" class="hover:text-white">אימון זוגי</a></li>
          <li><a href="/specialties/parents" class="hover:text-white">הדרכת הורים</a></li>
          <li><a href="/specialties/youth" class="hover:text-white">אימון לנוער</a></li>
          <li><a href="/specialties/personal" class="hover:text-white">התפתחות אישית</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4">השיטה</h4>
        <ul class="space-y-2 text-white/70">
          <li><a href="/method" class="hover:text-white">שיטת מ.ס.ע</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4">ניווט</h4>
        <ul class="space-y-2 text-white/70">
          <li><a href="/" class="hover:text-white">דף הבית</a></li>
          <li><a href="/about" class="hover:text-white">אודות</a></li>
          <li><a href="/articles" class="hover:text-white">מאמרים</a></li>
          <li><a href="/pain" class="hover:text-white">מרכז המידע</a></li>
          <li><a href="/contact" class="hover:text-white">צור קשר</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4">עקבו אחרי</h4>
        <div class="flex gap-3">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/heartcompass3/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition flex items-center justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/share/1AGLnvhmiF/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition flex items-center justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/yossi-medalsi-2a643a397/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition flex items-center justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/972544580285"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition flex items-center justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="currentColor" class="w-5 h-5">
              <path d="M16 3C9.4 3 4 8.3 4 14.8c0 2.2.6 4.2 1.8 6L4 29l8.4-1.8c1.1.3 2.3.5 3.6.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3Zm0 21.6c-1.2 0-2.3-.2-3.3-.6l-.6-.2-5 1.1 1.1-4.8-.3-.6c-1-1.6-1.6-3.4-1.6-5.4C6.3 9.3 10.7 5 16 5s9.7 4.3 9.7 9.6-4.4 10-9.7 10Z"/>
              <path d="M22.1 18.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.8.9-1 .9-.2.1-.4.1-.7-.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.6c.2-.2.2-.4.3-.6.1-.2 0-.4 0-.6-.1-.1-.7-1.7-1-2.3-.3-.6-.6-.5-.8-.5h-.7c-.2 0-.5.1-.7.4-.2.3-1 1-1 2.4 0 1.4 1 2.7 1.1 2.9.1.2 2 3 4.9 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4 0-.1-.3-.2-.6-.3Z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-2">
          אם הגעת עד לכאן – כנראה שמשהו בך כבר מחפש שינוי
        </h4>
        <p class="text-white/70 text-sm leading-relaxed mb-4">
          אני לא שולח ספאם. רק תובנות חדות על דפוסים, פחדים והבחירות שאנחנו עושים מתחת לרדאר.  
          דברים שיכולים להזיז אותך מבפנים.
        </p>
        <form action="https://formsubmit.co/yossi1974@outlook.co.il" method="POST" class="flex flex-col gap-2">
          <input type="text" name="name" placeholder="איך קוראים לך?" required class="p-2 rounded text-black" />
          <input type="email" name="email" placeholder="לאן לשלוח לך את זה?" required class="p-2 rounded text-black" />
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_subject" value="ליד חדש מהאתר מצפן הלב">
          <input type="hidden" name="_next" value="https://heartcompass.co.il/thank-you">
          <button type="submit" class="bg-white text-black py-2 rounded hover:bg-gray-200">
            כן, שלח לי תובנות
          </button>
        </form>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-white/50 text-sm">
      <p>© {new Date().getFullYear()} מצפן הלב. כל הזכויות שמורות.</p>
      <div class="flex flex-wrap gap-5 justify-center">
        <a href="/accessibility" class="hover:text-white">הצהרת נגישות</a>
        <a href="/privacy" class="hover:text-white">מדיניות פרטיות</a>
        <a href="/terms" class="hover:text-white">תנאי שימוש</a>
      </div>
    </div>
  </div>
</footer>