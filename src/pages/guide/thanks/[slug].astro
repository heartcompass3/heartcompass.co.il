---
import { sanity } from '../../../lib/sanity'

const { slug } = Astro.params;
let pdfUrl = null;

if (slug) {
  const guideData = await sanity.fetch(
    `*[_type == "landingPage" && slug.current == $slug][0]{ "pdfUrl": leadMagnet.asset->url }`,
    { slug }
  );
  pdfUrl = guideData?.pdfUrl;
}
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>תודה - המדריך שלך מוכן</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;700&display=swap" rel="stylesheet">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900 font-['Assistant',sans-serif] antialiased">
  <main class="min-h-screen flex items-center justify-center p-6 text-center">
    <div class="max-w-xl w-full bg-white p-12 rounded-3xl shadow-xl border border-slate-100">

      <div class="mb-8 flex justify-center text-green-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold mb-6 italic text-slate-900">ההרשמה בוצעה בהצלחה</h1>
      <p class="text-xl text-slate-600 mb-10 leading-relaxed">המדריך מחכה לך בלחיצה על הכפתור למטה.</p>

      {pdfUrl ? (
        <a href={pdfUrl} target="_blank" rel="noopener noreferrer" download="מדריך-מצפן-הלב.pdf"
           class="inline-block w-full bg-slate-900 hover:bg-black text-white font-bold text-xl py-5 rounded-xl transition-all shadow-lg mb-12 cursor-pointer">
          להורדת המדריך (PDF)
        </a>
      ) : (
        <div class="p-6 bg-red-50 text-red-700 border border-red-200 rounded-xl mb-12 font-bold">
          קובץ המדריך מתעדכן כרגע במערכת. אם הבעיה נמשכת, אנא ודא שהקובץ הועלה לסאניטי בהצלחה.
        </div>
      )}

      <div class="border-t border-slate-100 pt-8">
        <p class="text-slate-400 mb-6 text-sm italic">נשארים בקשר:</p>
        <div class="flex justify-center gap-10">
          <a href="https://wa.me/972544580285" target="_blank" class="text-slate-600 hover:text-green-500 transition-all scale-110">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 0 5.415 0 12.05c0 2.122.554 4.197 1.597 6.013L0 24l6.135-1.61a11.893 11.893 0 005.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.852 11.852 0 00-3.541-8.502z"/></svg>
          </a>
          <a href="https://facebook.com/yossimedalsi1?locale=he_IL" target="_blank" class="text-slate-600 hover:text-blue-600 transition-all scale-110">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://heartcompass.co.il/" target="_blank" class="text-slate-600 hover:text-slate-900 transition-all scale-110">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
