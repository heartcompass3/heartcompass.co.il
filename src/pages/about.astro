---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import site from '../content/pages/site.json'
import { sanity, urlFor } from '../lib/sanity'
import PortableText from '../components/PortableText.astro'

type AboutPage = {
  title?: string
  excerpt?: string
  heroImage?: any
  body?: any[]
  aiCitation?: string
  painTags?: string[]
  aiContext?: string
  seo?: {
    title?: string
    description?: string
    noindex?: boolean
    canonical?: string
    ogImage?: any
  }
}

const QUERY = /* groq */ `
  *[_type == "page" && slug.current == "about"][0]{
    title,
    excerpt,
    heroImage,
    body,
    aiCitation,
    painTags,
    aiContext,
    seo{
      title,
      description,
      noindex,
      canonical,
      ogImage
    }
  }
`

const page = await sanity.fetch<AboutPage | null>(QUERY)

// SEO
const metaTitle = page?.seo?.title || page?.title || `מי אני | ${site.brand}`
const metaDescription =
  page?.seo?.description || 'נעים להכיר. הסיפור של יוסי והדרך שבה נבנתה שיטת מ.ס.ע.'

// כותרת
const heading = page?.title?.trim() || `נעים להכיר, אני ${site.fullName}.`

// פתיחה (הזהוב)
const opening =
  page?.excerpt?.trim() ||
  'הייתי שם. אני יודע איך זה מרגיש כשהלב רוצה משהו אחד, והראש אומר משהו אחר.'

// תמונה
const fallbackImage = '/assets/yossi-about.jpg'
const imageSrc = page?.heroImage
  ? urlFor(page.heroImage).width(1000).height(1250).fit('crop').url()
  : fallbackImage

const ogImageUrl = page?.seo?.ogImage
  ? urlFor(page.seo.ogImage).width(1200).height(630).fit('crop').url()
  : undefined

// ─── Person schema עשיר לדף האודות ("כרטיס הביקור" של יוסי) ───────
const aboutUrl = `${site.siteUrl}/about`

const toAbsolute = (v: string) =>
  v.startsWith('http') ? v : `${site.siteUrl}${v.startsWith('/') ? '' : '/'}${v}`

const personDescription =
  page?.excerpt?.trim() ||
  metaDescription ||
  'יוסי מדלסי — מאמן רגשי מוסמך ICF ומייסד "מצפן הלב" ושיטת מ.ס.ע. מלווה בני נוער, הורים וזוגות בתהליכי עומק לשחרור דפוסים רגשיים.'

const aboutPersonSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site.siteUrl}/#person`,
  name: site.fullName,
  url: aboutUrl,
  jobTitle: 'מאמן רגשי מוסמך ICF',
  description: personDescription,
  email: site.email,
  image: toAbsolute(imageSrc),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'נתניה',
    addressRegion: 'מחוז המרכז',
    addressCountry: 'IL',
  },
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Professional Certification',
      name: 'מאמן רגשי מוסמך – ICF (International Coaching Federation)',
      recognizedBy: {
        '@type': 'Organization',
        name: 'International Coaching Federation',
        url: 'https://coachingfederation.org',
      },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Specialized Training',
      name: 'השתלמות מקצועית – אימון רגשי לבני נוער ומתבגרים',
    },
  ],
  knowsAbout: [
    'אימון רגשי',
    'אינטליגנציה רגשית',
    'הדרכת הורים',
    'ליווי זוגות',
    'בני נוער ומתבגרים',
    'שיטת מ.ס.ע',
  ],
  sameAs: [
    site.instagramUrl,
    site.facebookUrl,
    'https://www.linkedin.com/in/yossi-medalsi-2a643a397/',
    `https://wa.me/${site.whatsAppPhone}`,
  ],
  worksFor: { '@id': `${site.siteUrl}/#business` },
  mainEntityOfPage: aboutUrl,
  ...(page?.aiCitation ? { disambiguatingDescription: page.aiCitation } : {}),
  ...(page?.painTags?.length ? { keywords: page.painTags.join(', ') } : {}),
}
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={page?.seo?.canonical}
  noindex={page?.seo?.noindex}
  ogImage={ogImageUrl}
  schema={[aboutPersonSchema]}
>
  <article class="animate-fade-in py-24 bg-background">
    <div class="max-w-6xl mx-auto px-6">

      <!-- מובייל: כותרת + ציטוט זהב לפני התמונה -->
      <Breadcrumbs items={[{ name: 'אודות' }]} />
      <div class="md:hidden bg-white/60 backdrop-blur-xl rounded-[3rem] p-8 shadow-2xl border border-white/50 mb-10">
        <h1 class="text-5xl font-black text-primary font-display mb-8 leading-tight text-center">
          {heading}
        </h1>

        <div class="prose prose-xl text-primary/80 font-body leading-9 max-w-none text-center">
          <p class="mb-0 font-bold text-gold-dark text-2xl border-r-4 border-accent pr-4 bg-white/50 p-4 rounded-l-xl">
            "{opening}"
          </p>
        </div>
      </div>

      <!-- הקארד הראשי: בדסקטופ נשאר אותו לייאאוט, במובייל התמונה תבוא לפני הגוף -->
      <div class="bg-white/60 backdrop-blur-xl rounded-[3rem] p-8 md:p-20 shadow-2xl border border-white/50 relative overflow-hidden flex flex-col md:flex-row gap-16 items-center">

        <!-- תמונה -->
        <div class="w-full md:w-5/12 relative z-10">
          <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-all duration-700 border-[8px] border-white ring-1 ring-accent/20">
            <img
              src={imageSrc}
              alt={site.fullName}
              class="object-cover w-full h-full transform hover:scale-105 transition-transform duration-[1.5s]"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

        <!-- טקסט -->
        <div class="w-full md:w-7/12 relative z-10 text-center md:text-right">

          <!-- בדסקטופ: כותרת + ציטוט זהב בתוך הטקסט (כמו שהיה).
             זו אינה h1 כדי שלא יהיו שני h1 בעמוד (ה-h1 היחיד הוא גרסת המובייל). -->
          <div class="hidden md:block">
            <div role="heading" aria-level="1" class="text-6xl md:text-7xl font-black text-primary font-display mb-10 leading-tight">
              {heading}
            </div>

            <div class="prose prose-xl text-primary/80 font-body leading-9 max-w-none">
              <p class="mb-8 font-bold text-gold-dark text-2xl border-r-4 border-accent pr-4 bg-white/50 p-4 rounded-l-xl">
                "{opening}"
              </p>
            </div>
          </div>

          <!-- הגוף: גם מובייל וגם דסקטופ -->
          <div class=”prose prose-xl text-primary/80 font-body leading-9 max-w-none mt-10 md:mt-0”>
            {page?.body?.length ? (
              <PortableText value={page.body} />
            ) : (
              <p>עדיין אין תוכן בדף אודות בסאניטי. הוסף תוכן לשדה “תוכן”.</p>
            )}
          </div>

          <!-- ICF credential badge -->
          <div class=”mt-10 flex flex-wrap gap-4 justify-center md:justify-start” aria-label=”הסמכות מקצועיות”>
            <a
              href=”https://coachingfederation.org”
              target=”_blank”
              rel=”noopener noreferrer”
              class=”inline-flex items-center gap-3 bg-white/80 border border-accent/30 rounded-2xl px-5 py-3 shadow hover:shadow-md transition-shadow no-underline”
              aria-label=”מאמן מוסמך ICF – International Coaching Federation”
            >
              <svg width=”36” height=”36” viewBox=”0 0 36 36” fill=”none” xmlns=”http://www.w3.org/2000/svg” aria-hidden=”true”>
                <circle cx=”18” cy=”18” r=”18” fill=”#00539B”/>
                <path d=”M10 18C10 13.58 13.58 10 18 10C20.39 10 22.55 10.97 24.12 12.56L21.95 14.73C20.94 13.66 19.55 13 18 13C15.24 13 13 15.24 13 18C13 20.76 15.24 23 18 23C19.55 23 20.94 22.34 21.95 21.27L24.12 23.44C22.55 25.03 20.39 26 18 26C13.58 26 10 22.42 10 18Z” fill=”white”/>
                <path d=”M26 17H19V19H26V17Z” fill=”white”/>
                <path d=”M23 14H25V22H23V14Z” fill=”white”/>
              </svg>
              <div class=”text-right”>
                <div class=”text-xs text-primary/50 font-body leading-none mb-0.5”>הסמכה מקצועית</div>
                <div class=”text-sm font-bold text-primary font-display leading-none”>מאמן מוסמך ICF</div>
                <div class=”text-xs text-primary/60 font-body leading-none mt-0.5”>International Coaching Federation</div>
              </div>
            </a>
            <div class=”inline-flex items-center gap-3 bg-white/80 border border-accent/30 rounded-2xl px-5 py-3 shadow”>
              <svg width=”36” height=”36” viewBox=”0 0 36 36” fill=”none” xmlns=”http://www.w3.org/2000/svg” aria-hidden=”true”>
                <circle cx=”18” cy=”18” r=”18” fill=”#C8A96E”/>
                <path d=”M18 8L20.47 15.38H28.26L21.89 19.74L24.36 27.12L18 22.76L11.64 27.12L14.11 19.74L7.74 15.38H15.53L18 8Z” fill=”white”/>
              </svg>
              <div class=”text-right”>
                <div class=”text-xs text-primary/50 font-body leading-none mb-0.5”>הכשרה ייעודית</div>
                <div class=”text-sm font-bold text-primary font-display leading-none”>ליווי בני נוער</div>
                <div class=”text-xs text-primary/60 font-body leading-none mt-0.5”>השתלמות מקצועית מוסמכת</div>
              </div>
            </div>
          </div>

        </div>

      </div>
    </div>
  </article>
</BaseLayout>
