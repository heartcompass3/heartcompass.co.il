---
// Catch-all לעמודי "page" מ-Sanity (single-segment) שאין להם route ייעודי.
// עמודים עם route סטטי (about, articles, contact, tools...) מקבלים עדיפות
// אוטומטית ולא מגיעים לכאן. מונע 404 על עמודים שמקושרים מהניווט.
import BaseLayout from '../layouts/BaseLayout.astro'
import site from '../content/pages/site.json'
import { sanity, urlFor } from '../lib/sanity'
import { buildBreadcrumbListSchema } from '../lib/breadcrumbs'
import PortableText from '../components/PortableText.astro'

const { slug } = Astro.params

const page = await sanity.fetch(
  `*[_type == "page" && slug.current == $slug][0]{
    title,
    excerpt,
    body,
    specialty{
      intro,
      faqTitle,
      faq[]{ question, answer },
      closing
    },
    seo{
      title,
      description,
      noindex,
      canonical,
      ogImage
    }
  }`,
  { slug }
)

// אין מסמך מתאים → 404 אמיתי (לא עמוד ריק).
if (!page) {
  return new Response('Not found', { status: 404 })
}

const metaTitle = page.seo?.title || page.title || site.brand
const metaDescription =
  page.seo?.description || page.excerpt || site.heroDescription

const canonical =
  page.seo?.canonical || new URL(Astro.url.pathname, site.siteUrl).toString()

const ogImageUrl = page.seo?.ogImage
  ? urlFor(page.seo.ogImage).width(1200).height(630).fit('crop').url()
  : undefined

const heading = page.title?.trim() || site.brand
const opening = page.excerpt?.trim() || page.specialty?.intro?.trim() || ''
const closing = page.specialty?.closing?.trim() || ''

const faqs = page.specialty?.faq || []
const faqTitle = page.specialty?.faqTitle || 'שאלות נפוצות'

const breadcrumbSchema = buildBreadcrumbListSchema({
  siteUrl: site.siteUrl,
  brandName: site.brand,
  crumbs: [{ name: heading, item: canonical }],
})

// FAQPage schema — כדי שגוגל/AI יזהו את ה-FAQ. נפלט רק אם יש שאלות.
const faqSchema =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        '@id': `${canonical}#faq`,
        mainEntity: faqs.map((item: { question: string; answer: string }) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null

const schemaArray = [breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={canonical}
  noindex={page.seo?.noindex}
  ogImage={ogImageUrl}
  schema={schemaArray}
>
  <article class="animate-fade-in py-24 bg-background min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <header class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-black text-primary font-display leading-tight">
          {heading}
        </h1>

        {opening && (
          <p class="mt-8 text-xl text-accent font-body font-bold max-w-3xl mx-auto leading-relaxed">
            {opening}
          </p>
        )}
      </header>

      <div class="bg-white p-10 md:p-16 rounded-[3rem] shadow-2xl border border-white">
        <div class="prose prose-xl max-w-none text-primary/80 font-body leading-9">
          {page.body?.length ? (
            <PortableText value={page.body} />
          ) : (
            <p>עדיין אין תוכן לעמוד זה.</p>
          )}
        </div>

        {faqs.length > 0 && (
          <section class="mt-16 border-t border-primary/10 pt-12">
            <h2 class="text-2xl font-black text-primary font-display mb-8 text-center">
              {faqTitle}
            </h2>
            <div class="space-y-4">
              {faqs.map((item: { question: string; answer: string }) => (
                <details class="group border border-primary/10 rounded-2xl overflow-hidden bg-background">
                  <summary class="px-6 py-5 cursor-pointer font-bold text-primary font-body text-lg list-none flex justify-between items-center hover:bg-primary/5 transition-colors">
                    {item.question}
                    <span class="text-accent text-xl transition-transform group-open:rotate-45 mr-4">+</span>
                  </summary>
                  <div class="px-6 pb-6 pt-2 text-primary/70 font-body leading-relaxed text-base">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}

        {closing && (
          <div class="mt-12 bg-accent/10 border-r-4 border-accent rounded-2xl p-7 md:p-8 text-primary/85 font-body font-bold leading-relaxed text-center">
            {closing}
          </div>
        )}

        <div class="mt-12 text-center">
          <a
            href={site.primaryCtaHref}
            class="inline-flex items-center gap-3 px-10 py-4 rounded-2xl gradient-gold text-white font-bold shadow-gold hover:scale-105 transition-transform"
          >
            {site.primaryCtaLabel} <span aria-hidden="true">←</span>
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
